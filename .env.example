# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real credentials.

# Apple ID used for App Store Connect
APPLE_ID=your@apple.id

# 10-character Apple Developer Team ID
# Find at: https://developer.apple.com/account → Membership → Team ID
APP_STORE_CONNECT_TEAM_ID=XXXXXXXXXX

# iTunes Connect Team ID (usually same as above for individuals)
ITUNES_CONNECT_TEAM_ID=XXXXXXXXXX

# match encryption passphrase (used to encrypt certs/profiles in the git repo)
MATCH_PASSWORD=your-strong-passphrase-here

# Private git repo URL for match certificate storage
MATCH_GIT_URL=git@github.com:your-org/rosemount-certificates.git

# App Store Connect API Key (preferred over password — avoids 2FA prompts)
# Create at: https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Path to the downloaded .p8 key file (or paste contents as base64)
APP_STORE_CONNECT_API_KEY_PATH=~/private_keys/AuthKey_XXXXXXXXXX.p8

# Optional: Slack webhook URL for lane success/failure notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
