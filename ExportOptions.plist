<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>

    <!-- Replace XXXXXXXXXX with your 10-character Apple Developer Team ID -->
    <key>teamID</key>
    <string>XXXXXXXXXX</string>

    <!-- Upload symbols so crash reports are symbolicated in Organizer / TestFlight -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Upload app to App Store Connect automatically after export -->
    <key>destination</key>
    <string>upload</string>

    <!-- No bitcode since iOS 16+ (Apple deprecated it) -->
    <key>compileBitcode</key>
    <false/>

    <!-- Signing: match sets CODE_SIGN_STYLE=Manual; list provisioning profile here -->
    <key>provisioningProfiles</key>
    <dict>
        <key>social.rosemount.app</key>
        <string>match AppStore social.rosemount.app</string>
    </dict>

    <key>signingStyle</key>
    <string>manual</string>

    <key>signingCertificate</key>
    <string>Apple Distribution</string>
</dict>
</plist>
